{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "auth",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": {
          "PathPattern": "{**catch-all}"
        } 
      },
      {
        "RouteId": "finance",
        "ClusterId": "financeCluster",
        "Match": {
          "Path": "/api/finance/{**catch-all}"
        },
        "Transforms": {
          "PathPattern": "{**catch-all}"
        }
      }
    ],
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authDestination": {
            "Address": "https://localhost:5001/"
          }
        }
      },
      "financeCluster": {
        "Destinations": {
          "financeDestination": {
            "Address": "https://localhost:5000/"
          }
        }
      }
    }
  }
}
